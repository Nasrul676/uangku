<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="8dp"
    android:background="@drawable/uangku_widget_background"
    android:orientation="vertical"
    android:gravity="center_vertical"
    android:padding="16dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_wallet_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Sisa Saldo"
            android:textColor="#FF2D2D2D"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/widget_toggle_visibility_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/uangku_widget_income_cta_background"
            android:paddingLeft="8dp"
            android:paddingTop="4dp"
            android:paddingRight="8dp"
            android:paddingBottom="4dp"
            android:drawableStart="@drawable/ic_widget_visibility"
            android:drawablePadding="4dp"
            android:text="Hide"
            android:textColor="#FF111111"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Sisa Saldo Value -->
    <TextView
        android:id="@+id/widget_balance_value"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Rp 0"
        android:textColor="#FF111111"
        android:textSize="20sp"
        android:textStyle="bold" />

</LinearLayout>
