<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_margin="8dp"
    android:background="@drawable/uangku_widget_background"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_wallet_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Sisa Saldo"
            android:textColor="#FF2D2D2D"
            android:textSize="13sp" />

        <TextView
            android:id="@+id/widget_toggle_visibility_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/uangku_widget_income_cta_background"
            android:paddingLeft="8dp"
            android:paddingTop="4dp"
            android:paddingRight="8dp"
            android:paddingBottom="4dp"
            android:drawableStart="@drawable/ic_widget_visibility"
            android:drawablePadding="4dp"
            android:text="Hide"
            android:textColor="#FF111111"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Sisa Saldo Value -->
    <TextView
        android:id="@+id/widget_balance_value"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Rp 0"
        android:textColor="#FF111111"
        android:textSize="20sp"
        android:textStyle="bold" />

    <!-- Pemasukan & Pengeluaran Row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        android:baselineAligned="false">

        <!-- Pemasukan Column -->
        <LinearLayout
            android:id="@+id/widget_income_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:orientation="vertical"
            android:background="@drawable/uangku_widget_income_cta_background"
            android:padding="8dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/widget_income_icon"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_widget_income" />

                <TextView
                    android:id="@+id/widget_income_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="Pemasukan"
                    android:textColor="#FF2D2D2D"
                    android:textSize="10sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/widget_income_value"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Rp 0"
                android:textColor="#FF111111"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- Pengeluaran Column -->
        <LinearLayout
            android:id="@+id/widget_expense_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:orientation="vertical"
            android:background="@drawable/uangku_widget_income_cta_background"
            android:padding="8dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/widget_expense_icon"
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_widget_expense" />

                <TextView
                    android:id="@+id/widget_expense_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="Pengeluaran"
                    android:textColor="#FF2D2D2D"
                    android:textSize="10sp" />
            </LinearLayout>

            <TextView
                android:id="@+id/widget_expense_value"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:ellipsize="end"
                android:maxLines="1"
                android:text="Rp 0"
                android:textColor="#FFC24545"
                android:textSize="12sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
